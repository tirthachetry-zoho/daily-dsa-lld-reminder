# Database (Supabase PostgreSQL)
# Replace YOUR_SUPABASE_DB_PASSWORD with the DB password from Supabase → Settings → Database
# DATABASE_URL uses the Supabase *pooled* connection string (Session mode / port 6543)
# DIRECT_URL uses the Supabase *direct* connection string (port 5432) for Prisma migrations
DATABASE_URL="postgresql://postgres.welybuztlkhabvkqecjs:YOUR_SUPABASE_DB_PASSWORD@aws-0-ap-south-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres:YOUR_SUPABASE_DB_PASSWORD@aws-0-ap-south-1.db.supabase.com:5432/postgres"

# Supabase
NEXT_PUBLIC_SUPABASE_URL="https://welybuztlkhabvkqecjs.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# Resend
RESEND_API_KEY="your-resend-api-key"
EMAIL_FROM="noreply@yourdomain.com"

# NextAuth
NEXTAUTH_SECRET="your-nextauth-secret"
NEXTAUTH_URL="http://localhost:3000"
